{
  "id": "A1B2C3D4-E5F6-7890-ABCD-EF1234567807",
  "treePath": "ui/quasar",
  "name": "QCarouselControl",
  "importStr": "import { QCarouselControl } from \"quasar\"",
  "tag": "QCarouselControl",
  "parentMustBe": ["QCarousel"],
  "type": "component",
  "meta": {
    "docsUrl": "https://v2.quasar.dev/vue-components/carousel"
  },
  "props": {
    "position": {
      "type": "String",
      "desc": "Side/corner to stick to",
      "default": "bottom-right",
      "values": ["top-right", "top-left", "bottom-right", "bottom-left", "top", "right", "bottom", "left"],
      "category": "position",
      "desc_cn": "控制器停靠的位置"
    },
    "offset": {
      "type": "Array",
      "desc": "An array of two numbers to offset the Carousel Control horizontally and vertically in pixels",
      "default": "[18, 18]",
      "examples": ["[8, 8]", "[5, 10]"],
      "category": "position",
      "desc_cn": "水平和垂直偏移量（像素）"
    }
  },
  "slots": {
    "default": {
      "desc": "Control content; Suggestion: QBtn",
      "desc_cn": "控制器内容；建议使用 QBtn"
    }
  },
  "events": {}
}
