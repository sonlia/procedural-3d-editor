{
  "id": "CE496B61-2876-50E8-2AEE-788C9BC08421",
  "treePath": "ui/quasar",
  "name": "QScrollObserver",
  "importStr": "import { QScrollObserver } from \"quasar\"",
  "tag": "QScrollObserver",
  "parentMustBe": [],
  "type": "component",
  "meta": {
    "docsUrl": "https://v2.quasar.dev/vue-components/scroll-observer"
  },
  "props": {
    "debounce": {
      "type": [
        "String",
        "Number"
      ],
      "desc": "Debounce amount (in milliseconds)",
      "examples": [
        "0",
        "530"
      ],
      "category": "behavior",
      "desc_cn": "防抖延迟时间（以毫秒为单位）"
    },
    "axis": {
      "type": "String",
      "desc": "Axis on which to detect changes",
      "values": [
        "both",
        "vertical",
        "horizontal"
      ],
      "default": "vertical",
      "category": "behavior",
      "required": false,
      "desc_cn": "用于检测变化的轴"
    },
    "scroll-target": {
      "type": [
        "Element",
        "String"
      ],
      "desc": "CSS selector or DOM element to be used as a custom scroll container instead of the auto detected one",
      "examples": [
        ":scroll-target=\"$refs.scrollTarget\"",
        "scroll-target=\".scroll-target-class\"",
        "scroll-target=\"#scroll-target-id\"",
        "scroll-target=\"body\""
      ],
      "category": "behavior",
      "desc_cn": "用作自定义滚动容器的 CSS 选择器或 DOM 元素，而不是自动检测到的容器。"
    }
  },
  "events": {
    "scroll": {
      "desc": "Emitted when scroll position changes",
      "params": {
        "details": {
          "type": "Object",
          "desc": "Scroll details",
          "definition": {
            "position": {
              "type": "Object",
              "required": true,
              "desc": "Scroll offset (from top and left)",
              "definition": {
                "top": {
                  "type": "Number",
                  "required": true,
                  "desc": "Scroll offset from top (vertical)",
                  "desc_cn": "从顶部滚动的偏移量（垂直）"
                },
                "left": {
                  "type": "Number",
                  "required": true,
                  "desc": "Scroll offset from left (horizontal)",
                  "desc_cn": "从左侧滚动偏移量（水平）"
                }
              },
              "desc_cn": "滚动偏移量（从顶部和左侧）"
            },
            "direction": {
              "type": "String",
              "required": true,
              "desc": "Direction of scroll",
              "values": [
                "up",
                "down",
                "left",
                "right"
              ],
              "desc_cn": "滚动的方向"
            },
            "directionChanged": {
              "type": "Boolean",
              "required": true,
              "desc": "Has scroll direction changed since event was last emitted?",
              "desc_cn": "滚动方向自上次事件发出以来是否发生了变化？"
            },
            "delta": {
              "type": "Object",
              "required": true,
              "desc": "Delta of distance (in pixels) since event was last emitted",
              "definition": {
                "top": {
                  "type": "Number",
                  "required": true,
                  "desc": "Vertical delta distance since event was last emitted",
                  "desc_cn": "事件最后一次触发以来的垂直位移距离"
                },
                "left": {
                  "type": "Number",
                  "required": true,
                  "desc": "Horizontal delta distance since event was last emitted",
                  "desc_cn": "事件最后一次触发以来的水平位移距离"
                }
              },
              "desc_cn": "事件最后一次触发以来的距离增量（以像素为单位）"
            },
            "inflectionPoint": {
              "type": "Object",
              "required": true,
              "desc": "Last scroll offset where scroll direction has changed",
              "definition": {
                "top": {
                  "type": "Number",
                  "required": true,
                  "desc": "Scroll offset from top (vertical)",
                  "desc_cn": "从顶部滚动的偏移量（垂直）"
                },
                "left": {
                  "type": "Number",
                  "required": true,
                  "desc": "Scroll offset from left (horizontal)",
                  "desc_cn": "从左侧滚动偏移量（水平）"
                }
              },
              "desc_cn": "滚动方向改变时的最后滚动偏移量"
            }
          },
          "desc_cn": "滚动详情"
        }
      },
      "desc_cn": "滚动位置发生变化时触发"
    }
  },
  "methods": {
    "trigger": {
      "desc": "Emit a 'scroll' event",
      "params": {
        "immediately": {
          "type": "Boolean",
          "desc": "Skip over the debounce amount",
          "desc_cn": "跳过防抖时间间隔"
        }
      },
      "desc_cn": "触发一个 'scroll' 事件"
    },
    "getPosition": {
      "desc": "Get current scroll details under the form of an Object: { position, direction, directionChanged, inflectionPoint }",
      "desc_cn": "以一个对象的形式获取当前滚动细节：{ position, direction, directionChanged, inflectionPoint }"
    }
  }
}
