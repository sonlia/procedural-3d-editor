{
  "id": "A1B2C3D4-E5F6-7890-ABCD-EF1234567806",
  "treePath": "ui/quasar",
  "name": "QCarouselSlide",
  "importStr": "import { QCarouselSlide } from \"quasar\"",
  "tag": "QCarouselSlide",
  "parentMustBe": ["QCarousel"],
  "type": "component",
  "meta": {
    "docsUrl": "https://v2.quasar.dev/vue-components/carousel"
  },
  "props": {
    "name": {
      "type": ["Any"],
      "desc": "Slide name",
      "required": true,
      "examples": ["slide-1", "slide-2"],
      "category": "model",
      "desc_cn": "幻灯片名称"
    },
    "disable": {
      "type": "Boolean",
      "desc": "Put component in disabled mode",
      "category": "state",
      "desc_cn": "将组件置于禁用模式"
    },
    "img-src": {
      "type": "String",
      "desc": "URL pointing to a slide background image",
      "examples": ["(public folder) img/my-bg.png", "(relative path format) ./img/my-bg.png", "(assets folder) ~assets/my-bg.png"],
      "category": "model",
      "desc_cn": "指向幻灯片背景图像的 URL"
    }
  },
  "slots": {
    "default": {
      "desc": "Slide content",
      "desc_cn": "幻灯片内容"
    }
  },
  "events": {}
}
